const TOKEN_KEY = 'seo_local_dashboard_token';

function resolveApiBases() {
  const configured = (import.meta as any).env?.VITE_API_URL;
  if (configured) return [String(configured).replace(/\/$/, '')];

  const host = typeof window !== 'undefined' ? window.location.hostname : 'localhost';
  const protocol = typeof window !== 'undefined' ? window.location.protocol : 'http:';
  const currentHostBase = `${protocol}//${host}:4000/api/v1`;

  const bases = [
    currentHostBase,
    'http://localhost:4000/api/v1',
    'http://127.0.0.1:4000/api/v1',
  ];

  return Array.from(new Set(bases));
}

const API_BASES = resolveApiBases();

const LAST_API_BASE_KEY = 'seo_local_dashboard_api_base';

export type DashboardSession = {
  token: string;
  user: { id: number; login: string; name: string; roleCode: string; agencyPartnerId?: number | null };
};

export type AdminListResponse<T = any> = { items: T[]; meta?: Record<string, any> };

function getToken() {
  return localStorage.getItem(TOKEN_KEY) || '';
}

function setToken(token: string) {
  localStorage.setItem(TOKEN_KEY, token);
}

export function clearAdminToken() {
  localStorage.removeItem(TOKEN_KEY);
}

function orderedBases() {
  const last = localStorage.getItem(LAST_API_BASE_KEY);
  if (last && API_BASES.includes(last)) {
    return [last, ...API_BASES.filter((base) => base !== last)];
  }
  return API_BASES;
}

async function request<T>(path: string, options: RequestInit = {}): Promise<T> {
  const headers = new Headers(options.headers || {});
  headers.set('Content-Type', 'application/json');
  const token = getToken();
  if (token) headers.set('Authorization', `Bearer ${token}`);

  const errors: string[] = [];

  for (const base of orderedBases()) {
    try {
      const response = await fetch(`${base}${path}`, { ...options, headers });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(payload.error || payload.message || `Error ${response.status}`);
      }
      localStorage.setItem(LAST_API_BASE_KEY, base);
      return payload as T;
    } catch (error: any) {
      errors.push(`${base}: ${error?.message || String(error)}`);
      // If API responded with business error, do not hide it behind another base.
      if (error?.message && !/Failed to fetch|NetworkError|Load failed|fetch/i.test(error.message)) {
        throw error;
      }
    }
  }

  throw new Error(`No se pudo conectar con la API del dashboard. Verifica que Docker tenga el servicio api activo en el puerto 4000. Detalle: ${errors.join(' | ')}`);
}

export const adminApi = {
  get token() { return getToken(); },
  async login(login: string, password: string) {
    const payload = await request<DashboardSession>('/admin/auth/login', {
      method: 'POST',
      body: JSON.stringify({ login, password }),
    });
    setToken(payload.token);
    return payload;
  },
  me: () => request<DashboardSession>('/admin/auth/me'),
  summary: () => request<any>('/admin/dashboard/summary'),
  agencies: () => request<AdminListResponse>('/admin/agencies'),
  updateAgency: (id: number, data: any) => request(`/admin/agencies/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  categories: () => request<AdminListResponse>('/admin/categories'),
  updateCategory: (id: number, data: any) => request(`/admin/categories/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  services: () => request<AdminListResponse>('/admin/services'),
  updateService: (id: number, data: any) => request(`/admin/services/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  leads: () => request<AdminListResponse>('/admin/leads'),
  updateLead: (id: number, data: any) => request(`/admin/leads/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  reviews: () => request<AdminListResponse>('/admin/reviews'),
  updateReview: (id: number, data: any) => request(`/admin/reviews/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  plans: () => request<AdminListResponse>('/admin/plans'),
  updatePlan: (id: number, data: any) => request(`/admin/plans/${id}`, { method: 'PUT', body: JSON.stringify(data) }),
  audit: () => request<AdminListResponse>('/admin/activity'),
};
